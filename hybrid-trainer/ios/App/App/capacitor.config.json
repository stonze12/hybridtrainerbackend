{
	"appId": "com.hybridwarfare.trainer",
	"appName": "Hybrid Trainer",
	"webDir": "www",
	"bundledWebRuntime": false,
	"server": {
		"allowNavigation": [
			"api.anthropic.com",
			"world.openfoodfacts.org"
		]
	},
	"ios": {
		"scheme": "Hybrid Trainer",
		"backgroundColor": "#0a1216",
		"contentInset": "always",
		"scrollEnabled": false,
		"preferredContentMode": "mobile"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 1200,
			"backgroundColor": "#0a1216",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#0a1216"
		}
	},
	"packageClassList": []
}
